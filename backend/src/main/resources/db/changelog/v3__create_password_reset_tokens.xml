<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- =====================================================================
         changeset: 003 – Create password_reset_tokens table
         Stores temporary tokens for the forgot-password flow.
         ===================================================================== -->
    <changeSet id="003-create-password-reset-tokens" author="trade-journals">

        <createTable tableName="password_reset_tokens"
                     remarks="Stores one-time password reset tokens with expiry.
                              Tokens are generated when users request a password reset
                              and are invalidated after use or expiry.">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_password_reset_token"/>
            </column>

            <column name="token" type="VARCHAR(255)"
                    remarks="UUID v4 reset token sent to the user's email">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_prt_token"/>
            </column>

            <column name="user_id" type="BIGINT"
                    remarks="FK to users table">
                <constraints nullable="false"/>
            </column>

            <column name="expires_at" type="TIMESTAMP(6)"
                    remarks="Token expiry time (UTC)">
                <constraints nullable="false"/>
            </column>

            <column name="used" type="BOOLEAN" defaultValueBoolean="false"
                    remarks="Whether this token has already been consumed">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMP(6)"/>

        </createTable>

        <addForeignKeyConstraint
            baseTableName="password_reset_tokens"
            baseColumnNames="user_id"
            constraintName="fk_prt_user"
            referencedTableName="users"
            referencedColumnNames="id"
            onDelete="CASCADE"/>

        <createIndex tableName="password_reset_tokens" indexName="idx_prt_user_id">
            <column name="user_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
